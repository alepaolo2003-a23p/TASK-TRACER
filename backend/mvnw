#!/bin/sh
MVN_VERSION="3.9.8"
MVN_CACHE="$HOME/.m2/cache"
MVN_HOME="$MVN_CACHE/apache-maven-$MVN_VERSION"

if [ ! -f "$MVN_HOME/bin/mvn" ]; then
    echo "Downloading Maven $MVN_VERSION..."
    mkdir -p "$MVN_CACHE"
    URL="https://archive.apache.org/dist/maven/maven-3/$MVN_VERSION/binaries/apache-maven-$MVN_VERSION-bin.tar.gz"
    curl -fsSL "$URL" -o /tmp/maven.tar.gz
    tar -xzf /tmp/maven.tar.gz -C "$MVN_CACHE"
    rm -f /tmp/maven.tar.gz
fi

exec "$MVN_HOME/bin/mvn" "$@"
